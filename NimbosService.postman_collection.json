{
  "info": {
    "name": "NimbosService",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Paste the UserId/token returned by POST /users here"
    },
    {
      "key": "taskId",
      "value": "",
      "type": "string",
      "description": "Paste a task Id returned by any task endpoint here"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register (POST /users)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token saved:', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"test-device-001\",\n  \"name\": \"Varun\",\n  \"vibe\": \"calm\",\n  \"pin\": \"1234\",\n  \"tasks\": [\"Morning run\", \"Read 30 mins\", \"Meditate\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "Register a new user. Automatically saves the returned token to the `token` collection variable."
          }
        },
        {
          "name": "Get Me (GET /users/me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Fetch full user state on app launch."
          }
        },
        {
          "name": "Update Me (PATCH /users/me)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Varun Updated\",\n  \"vibe\": \"focused\",\n  \"pin\": \"5678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Update name, vibe, or PIN. All fields are optional."
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task (POST /tasks)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('taskId', json.id);",
                  "  console.log('Task Id saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Evening walk\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Add a new recurring habit. Automatically saves the returned task Id to the `taskId` collection variable."
          }
        },
        {
          "name": "Update Task (PATCH /tasks/{id})",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isCompleted\": true,\n  \"isSnoozed\": false,\n  \"isDismissedToday\": false,\n  \"isSkippedTomorrow\": false,\n  \"title\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "Toggle complete/snooze/dismiss/skipTomorrow or rename a task. All fields are optional."
          }
        },
        {
          "name": "Delete Task (DELETE /tasks/{id})",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "Permanently remove a recurring habit."
          }
        },
        {
          "name": "Create Tomorrow Extra (POST /tasks/tomorrow-extras)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('taskId', json.id);",
                  "  console.log('Tomorrow extra Id saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy groceries\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks/tomorrow-extras",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "tomorrow-extras"]
            },
            "description": "Add a one-time task that only appears tomorrow. Saves the returned Id to `taskId`."
          }
        },
        {
          "name": "Delete Tomorrow Extra (DELETE /tasks/tomorrow-extras/{id})",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/tomorrow-extras/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "tomorrow-extras", "{{taskId}}"]
            },
            "description": "Remove a tomorrow-only task."
          }
        }
      ]
    },
    {
      "name": "Daily",
      "item": [
        {
          "name": "New Day (POST /daily/new-day)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lastOpenedDate\": \"2026-03-29\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/daily/new-day",
              "host": ["{{baseUrl}}"],
              "path": ["daily", "new-day"]
            },
            "description": "Trigger the daily reset. Pass the date the app was last opened (yyyy-MM-dd). If it's before today a full reset runs; otherwise returns current state unchanged."
          }
        },
        {
          "name": "Get Snapshots (GET /daily/snapshots)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/daily/snapshots?month=2026-03",
              "host": ["{{baseUrl}}"],
              "path": ["daily", "snapshots"],
              "query": [
                {
                  "key": "month",
                  "value": "2026-03",
                  "description": "Format: yyyy-MM"
                }
              ]
            },
            "description": "Fetch all daily completion snapshots for a given calendar month."
          }
        }
      ]
    }
  ]
}
